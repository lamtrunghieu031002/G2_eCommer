# Copy file nay thanh .env trong thu muc cua tung service (hoac set bien moi truong)

# Database (mac dinh khop voi docker-compose.yml)
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT secret DUNG CHUNG cho user/product/order/payment service (Base64)
# Doi gia tri nay khi trien khai that!
JWT_SECRET=<sinh bang: openssl rand -base64 32>

# chatbot-service
GEMINI_API_KEY=your_gemini_api_key_here

# payment-service
VNPAY_TMN_CODE=your_tmn_code
VNPAY_HASH_SECRET=your_hash_secret
